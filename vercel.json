{
  "builds": [
    {
      "src": "api/contact.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/contact",
      "dest": "/api/contact.js"
    },
    {
      "src": "/hakkimizda",
      "dest": "/hakkimizda.html"
    },
    {
      "src": "/urunler",
      "dest": "/urunler.html"
    },
    {
      "src": "/uretim",
      "dest": "/uretim.html"
    },
    {
      "src": "/kalite",
      "dest": "/kalite.html"
    },
    {
      "src": "/iletisim",
      "dest": "/iletisim.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
